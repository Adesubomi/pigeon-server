# App
APP_NAME=pigeon
APP_ENV=development
APP_PORT=18080
SERVICE_NAME=pigeon-server
APP_KEY=--change-me

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pigeon
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GitHub OAuth
# Create these at https://github.com/settings/developers.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WEB_APP_URL=http://localhost:3000
# Comma-separated exact callback URLs in addition to WEB_APP_URL/auth/callback.
OAUTH_REDIRECT_ALLOWLIST=

# Authentication
AUTH_ACCESS_TOKEN_TTL=1h

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
