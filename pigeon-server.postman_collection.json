{
  "info": {
    "_postman_id": "aa0b9832-9b14-40a3-9608-20fd013e61a3",
    "name": "pigeon-server local",
    "description": "Local smoke collection for pigeon-server. Run against a server started with APP_PORT=18080 go run ./cmd/server. Authenticated user routes require a valid Bearer access token; the included local environment contains the dev token seeded during the 2026-05-30 smoke test.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('response is not a server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('health is ok', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/healthz"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "GET /auth/github",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('GitHub auth URL is returned or OAuth is not configured locally', function () {",
                  "  pm.expect([200, 503]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/auth/github"
          },
          "response": []
        },
        {
          "name": "POST /auth/github/exchange",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('GitHub exchange succeeds or is not configured locally', function () {",
                  "  pm.expect([200, 503, 401]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.environment.set('access_token', body.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
