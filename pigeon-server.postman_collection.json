            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"replace-with-github-oauth-code\",\n  \"redirect_uri\": \"\"\n}"
            },
            "url": "{{base_url}}/auth/github/exchange"
          },
          "response": []
        },
        {
          "name": "GET /me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
